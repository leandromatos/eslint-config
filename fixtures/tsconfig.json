{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "moduleResolution": "Node",
    "esModuleInterop": true,
