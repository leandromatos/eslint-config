{
  "name": "@leandromatos/eslint-config",
  "version": "3.0.0-snapshot.20260705.1",
  "description": "ESLint flat configuration with TypeScript, React, import sorting, JSON, and Markdown support.",
  "keywords": [
    "eslint",
    "config"
  ],
  "license": "MIT",
  "author": "Leandro Matos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandromatos/eslint-config.git"
  },
  "type": "module",
  "main": "index.js",
  "exports": "./index.js",
  "files": [
    "index.js",
    "LICENSE"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "lint": "yarn lint:js",
    "lint:js": "eslint .",
    "lint:fix": "yarn lint:fix:js",
    "lint:fix:js": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "release:snapshot": "./scripts/snapshot-version-bump.sh",
    "release:production": "./scripts/production-version-bump.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "eslint": ">=10",
    "typescript": ">=5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@leandromatos/commitlint-config": "^0.6.0-snapshot.20260705.1",
    "@leandromatos/prettier-config": "^2.0.0-snapshot.20260705.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
