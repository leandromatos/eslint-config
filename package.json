{
  "name": "@leandromatos/eslint-config",
  "version": "3.0.0-rc.28",
  "repository": "https://github.com/leandromatos/eslint-config",
  "author": "Leandro Matos",
  "license": "MIT",
  "keywords": [
    "eslint",
    "config"
  ],
  "files": [
    "lib/**",
    "LICENSE"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "yarn clean:build && yarn compile && yarn resolve-alias",
    "clean:build": "rm -rf lib/*",
    "resolve-alias": "tsc-alias",
    "compile": "tsc",
    "lint:fix": "yarn build && yarn lint --fix",
    "lint": "yarn build && eslint .",
    "prepare": "husky",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/lint-staged": "^13.3.0",
    "@types/node": "^22.13.10",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "tsc-alias": "^1.8.11"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    }
  }
}
