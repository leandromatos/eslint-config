{
  "name": "@leandromatos/eslint-config",
  "version": "3.0.0-rc.37",
  "repository": "https://github.com/leandromatos/eslint-config",
  "author": "Leandro Matos",
  "license": "MIT",
  "keywords": [
    "eslint",
    "config"
  ],
  "files": [
    "lib/**",
    "LICENSE"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "yarn clean:build && yarn compile && yarn resolve-alias",
    "clean:build": "rm -rf lib/*",
    "resolve-alias": "tsc-alias",
    "compile": "tsc",
    "lint:fix": "yarn build && yarn lint --fix",
    "lint": "yarn build && eslint .",
    "prepare": "husky",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/lint-staged": "^14.0.0",
    "@types/node": "^24.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "tsc-alias": "^1.8.16"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  }
}
